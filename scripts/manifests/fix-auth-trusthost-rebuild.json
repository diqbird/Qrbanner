{
  "upload": [
    "lib/auth-options.ts",
    "hooks/use-login-form-submit.ts",
    "lib/i18n/en.ts",
    "lib/i18n/tr.ts",
    "scripts/reset-admin-password.mjs"
  ],
  "yarn_install": false,
  "prisma_generate": false,
  "prisma_migrate": false,
  "build": false,
  "restart": false,
  "extra_commands": [
    "grep -q '^AUTH_TRUST_HOST=' /var/www/qrbanner/.env && sed -i 's/^AUTH_TRUST_HOST=.*/AUTH_TRUST_HOST=true/' /var/www/qrbanner/.env || echo 'AUTH_TRUST_HOST=true' >> /var/www/qrbanner/.env",
    "cd /var/www/qrbanner && node scripts/reset-admin-password.mjs onur@qrbanner.com '112358Onrks..' 2>&1 | tail -2",
    "cd /var/www/qrbanner && rm -rf .next && yarn build 2>&1 | tail -20",
    "test -f /var/www/qrbanner/.next/server/pages/_error.js && echo ERROR_JS_OK || echo ERROR_JS_MISSING",
    "pm2 restart qrbanner --update-env 2>&1 | tail -2"
  ]
}
