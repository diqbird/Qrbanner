{
  "upload": [
    "app/(admin)/admin/ai/page.tsx",
    "app/(admin)/admin/backup/page.tsx",
    "app/(admin)/admin/banners/page.tsx",
    "app/(admin)/admin/campaigns/page.tsx",
    "app/(admin)/admin/menus/page.tsx",
    "app/(admin)/admin/notifications/page.tsx",
    "app/(admin)/admin/support/page.tsx",
    "app/(public)/layout.tsx",
    "app/api/admin/ai/route.ts",
    "app/api/admin/backup/route.ts",
    "app/api/admin/banners/route.ts",
    "app/api/admin/campaigns/route.ts",
    "app/api/admin/menus/route.ts",
    "app/api/admin/notifications/route.ts",
    "app/api/admin/support/route.ts",
    "app/api/contact/inquiry/route.ts",
    "components/admin/pages/admin-ai-page.tsx",
    "components/admin/pages/admin-backup-page.tsx",
    "components/admin/pages/admin-banners-page.tsx",
    "components/admin/pages/admin-campaigns-page.tsx",
    "components/admin/pages/admin-menus-page.tsx",
    "components/admin/pages/admin-notifications-page.tsx",
    "components/admin/pages/admin-support-page.tsx",
    "components/marketing/announcement-banner.tsx",
    "lib/admin-audit.ts",
    "lib/admin/modules.ts",
    "lib/admin/query-keys.ts",
    "lib/i18n/en.ts",
    "lib/i18n/tr.ts",
    "lib/site-settings-server.ts",
    "lib/site-settings.ts",
    "prisma/schema.prisma",
    "prisma/migrations/0004_contact_inquiries/migration.sql"
  ],
  "yarn_install": false,
  "prisma_generate": true,
  "prisma_migrate": true,
  "build": false,
  "restart": false,
  "extra_commands": [
    "cd /var/www/qrbanner && rm -rf .next && yarn build 2>&1 | tail -15",
    "test -f /var/www/qrbanner/.next/server/pages/_error.js && echo ERROR_JS_OK || echo ERROR_JS_MISSING",
    "pm2 restart qrbanner --update-env 2>&1 | tail -2",
    "sleep 6",
    "curl -s -o /dev/null -w 'HOME_HTTP:%{http_code}\\n' http://127.0.0.1:3000/",
    "curl -s -o /dev/null -w 'ADMIN_HTTP:%{http_code}\\n' http://127.0.0.1:3000/admin"
  ]
}
