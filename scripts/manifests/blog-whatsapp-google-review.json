{
  "upload": [
    "lib/blog/posts/whatsapp-ordering-qr.ts",
    "lib/blog/posts/google-review-qr.ts",
    "lib/blog/posts-service.ts"
  ],
  "yarn_install": false,
  "prisma_generate": false,
  "prisma_migrate": false,
  "build": true,
  "restart": true,
  "extra_commands": [
    "test -f /var/www/qrbanner/.next/server/pages/_error.js && echo ERROR_JS_OK || echo ERROR_JS_MISSING",
    "sleep 4",
    "for s in whatsapp-ordering-qr-codes google-review-qr-codes; do curl -s -o /dev/null -w \"$s:%{http_code}\\n\" http://127.0.0.1:3000/blog/$s; done",
    "curl -s https://qrbanner.com/sitemap.xml | grep -c '/blog/whatsapp-ordering-qr-codes\\|/blog/google-review-qr-codes'"
  ]
}
