{
  "upload": [
    "next.config.js",
    "components/public/pricing-trust-bar.tsx",
    "components/public/pricing-page-content.tsx",
    "components/dashboard/onboarding-checklist.tsx",
    "lib/i18n/en.ts",
    "lib/i18n/tr.ts"
  ],
  "yarn_install": false,
  "prisma_generate": false,
  "prisma_migrate": false,
  "build": false,
  "restart": false,
  "extra_commands": [
    "cd /var/www/qrbanner && rm -rf .next && yarn build 2>&1 | tail -18",
    "test -f /var/www/qrbanner/.next/server/pages/_error.js && echo ERROR_JS_OK || echo ERROR_JS_MISSING",
    "pm2 restart qrbanner --update-env 2>&1 | tail -2",
    "sleep 6",
    "curl -s -o /dev/null -w 'PRICING_HTTP:%{http_code}\\n' http://127.0.0.1:3000/pricing",
    "curl -s http://127.0.0.1:3000/pricing | grep -o 'money-back guarantee' | head -1 || echo 'trust-bar-note: SSR text may be localized'"
  ]
}
