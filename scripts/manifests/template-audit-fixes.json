{
  "upload": [
    "components/templates/template-qr-preview.tsx",
    "components/templates/template-detail-header.tsx",
    "components/templates/template-marketplace-card.tsx",
    "lib/i18n/en.ts",
    "lib/i18n/tr.ts",
    "lib/industry-archetype-templates.ts",
    "lib/industry-templates.ts"
  ],
  "yarn_install": false,
  "prisma_generate": false,
  "prisma_migrate": false,
  "build": false,
  "restart": false,
  "extra_commands": [
    "cd /var/www/qrbanner && rm -rf .next && yarn build 2>&1 | tail -15",
    "test -f /var/www/qrbanner/.next/server/pages/_error.js && echo ERROR_JS_OK || echo ERROR_JS_MISSING",
    "pm2 restart qrbanner --update-env 2>&1 | tail -2",
    "sleep 6",
    "curl -s -o /dev/null -w 'TEMPLATES_HTTP:%{http_code}\\n' http://127.0.0.1:3000/templates",
    "curl -s -o /dev/null -w 'DETAIL_HTTP:%{http_code}\\n' http://127.0.0.1:3000/templates/hotels-hospitality"
  ]
}
