{
  "upload": ["lib/template-marketplace.ts"],
  "yarn_install": false,
  "prisma_generate": false,
  "prisma_migrate": false,
  "build": false,
  "restart": false,
  "extra_commands": [
    "cd /var/www/qrbanner && rm -rf .next && yarn build 2>&1 | tail -12",
    "test -f /var/www/qrbanner/.next/server/pages/_error.js && echo ERROR_JS_OK || echo ERROR_JS_MISSING",
    "pm2 restart qrbanner --update-env 2>&1 | tail -2",
    "sleep 6",
    "curl -s -o /dev/null -w 'TEMPLATES_HTTP:%{http_code}\\n' http://127.0.0.1:3000/templates"
  ]
}
