{
  "upload": [
    "app/(public)/pricing/page.tsx",
    "components/public/pricing-page-content.tsx",
    "components/public/pricing-faq.tsx",
    "components/onboarding/onboarding-success-card.tsx",
    "components/qr/qr-edit-view.tsx",
    "lib/i18n/pricing-faq-items.ts",
    "lib/i18n/en.ts",
    "lib/i18n/tr.ts"
  ],
  "yarn_install": false,
  "prisma_generate": false,
  "prisma_migrate": false,
  "build": false,
  "restart": false,
  "extra_commands": [
    "cd /var/www/qrbanner && rm -rf .next && yarn build 2>&1 | tee /tmp/build.log | tail -6",
    "echo '=== HEAVIEST FIRST LOAD JS ==='",
    "grep -E 'First Load JS|kB' /tmp/build.log | grep -oE 'â—‹|Æ’|â—�|/[a-z0-9/_()\\[\\]-]* +[0-9.]+ [kM]B +[0-9.]+ [kM]B' 2>/dev/null | sort -t' ' -k3 -rh | head -12 || grep -E '[0-9]+ kB' /tmp/build.log | sort -k3 -rh | head -15",
    "echo '=== SHARED CHUNK ==='",
    "grep -E 'First Load JS shared|chunks/' /tmp/build.log | head -6",
    "test -f /var/www/qrbanner/.next/server/pages/_error.js && echo ERROR_JS_OK || echo ERROR_JS_MISSING",
    "pm2 restart qrbanner --update-env 2>&1 | tail -2",
    "sleep 5",
    "curl -s -o /dev/null -w 'PRICING_HTTP:%{http_code}\\n' http://127.0.0.1:3000/pricing"
  ]
}
