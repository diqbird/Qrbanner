{
  "upload": [],
  "yarn_install": false,
  "prisma_generate": false,
  "prisma_migrate": false,
  "build": true,
  "restart": true,
  "extra_commands": [
    "test -f /var/www/qrbanner/.next/server/pages/_error.js && echo ERROR_JS_OK || echo ERROR_JS_MISSING",
    "ls -d /var/www/qrbanner/.next-build 2>/dev/null && echo STALE_BUILD_DIR || echo NO_STALE_BUILD_DIR",
    "sleep 4 && pm2 jlist 2>/dev/null | node -e \"let d='';process.stdin.on('data',c=>d+=c).on('end',()=>{const a=JSON.parse(d);a.forEach(p=>console.log('PM2',p.name,p.pm2_env.status))})\"",
    "curl -s -o /dev/null -w 'HOME_HTTP:%{http_code}\\n' http://127.0.0.1:3000/"
  ]
}
