# Optional marketing integrations (add to VPS .env and rebuild)

# GA4 + optional GTM (Ads console A–D imports from GA4; GTM not required)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-3LY6YZDDD2
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Hero / demo video — also powers /demo and homepage hero when set
# NEXT_PUBLIC_HERO_VIDEO_URL=https://www.youtube.com/watch?v=YOUR_ID
# NEXT_PUBLIC_HERO_VIDEO_URL=https://www.loom.com/share/abc123
# NEXT_PUBLIC_HERO_VIDEO_URL=https://cdn.example.com/qrbanner-tour.mp4
# After setting, rebuild on VPS. Without this URL, homepage shows dashboard mockup + demo CTA.

# Hide caption bar under QR codes site-wide (default: shown). Set to false to remove label + gap.
# NEXT_PUBLIC_SHOW_QR_DESCRIPTION=false

# Live chat — Crisp (https://crisp.chat)
# NEXT_PUBLIC_CRISP_WEBSITE_ID=your-crisp-website-id

# Review profile links (set when G2/Capterra profiles are live)
# NEXT_PUBLIC_G2_REVIEW_URL=https://www.g2.com/products/qrbanner/reviews
# NEXT_PUBLIC_CAPTERRA_REVIEW_URL=https://www.capterra.com/p/qrbanner/reviews
# Tip: share /reviews page with customers — includes step-by-step review guide

# SALES_INBOX=support@qrbanner.com
# NEXT_PUBLIC_DEMO_BOOKING_URL=https://calendly.com/...
# NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/...

# Referral reward — Stripe coupon for 5-referral Pro trial (create in Stripe Dashboard)
# STRIPE_REFERRAL_COUPON_ID=coupon_xxxxxxxx
