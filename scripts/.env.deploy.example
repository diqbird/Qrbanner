# Copy to .env.deploy (never commit) and load before running deploy scripts:
#
# Required
# DEPLOY_HOST=your.server.ip
#
# Preferred auth (SSH key)
# DEPLOY_SSH_KEY_PATH=C:\Users\you\.ssh\qrbanner_deploy
# DEPLOY_SSH_KEY_PASSPHRASE=
# DEPLOY_KNOWN_HOSTS=C:\Users\you\.ssh\known_hosts
# DEPLOY_STRICT_HOST_KEY=1
#
# Legacy password auth (discouraged)
# DEPLOY_PASSWORD=your-ssh-password
#
# Paths
# DEPLOY_USER=root
# DEPLOY_REMOTE=/var/www/qrbanner
# DEPLOY_LOCAL=C:\Users\ACRO Technology\qrbanner
#
# App secrets (set on VPS .env — not used by deploy.py directly)
# HEALTH_DETAIL_SECRET=long-random-string
#   Generate on VPS: python scripts/set-vps-env.py --generate-health-secret
#   Read (ops only):  python scripts/set-vps-env.py --show HEALTH_DETAIL_SECRET
